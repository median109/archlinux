#!/usr/bin/env bash
set -e

# 颜色输出
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
RED=$'\033[0;31m'
CYAN=$'\033[0;36m'
NC=$'\033[0m'

info() { echo -e "${GREEN}[+]${NC} $1"; }
warn() { echo -e "${YELLOW}[!]${NC} $1"; }
error() {
  echo -e "${RED}[-]${NC} $1"
  exit 1
}
step() { echo -e "${CYAN}[*]${NC} $1"; }

usage() {
  cat <<EOF
${CYAN}gits${NC} - 智能 GitHub 内容下载与同步工具

${GREEN}用法:${NC}
  gits <github-url> [目标路径]
  gits push [to <仓库地址>] ["备注"] [-f]
  gits pull [路径]

${GREEN}下载模式:${NC}
  仓库:   https://github.com/owner/repo
  文件夹: https://github.com/owner/repo/tree/branch/path
  文件:   https://github.com/owner/repo/blob/branch/path/file

${GREEN}同步模式 (Push):${NC}
  gits push                  # 快速同步 (默认备注: 日常同步更新)
  gits push "修改了xxx"      # 带备注同步
  gits push to <url>         # 首次关联仓库并同步
  gits push to <url> "备注"  # 首次关联并带备注同步
  gits push "备注" -f        # 强制推送 (覆盖远程)

${GREEN}拉取模式 (Pull):${NC}
  gits pull                  # 拉取当前目录仓库
  gits pull <路径>           # 拉取指定路径仓库

${GREEN}特性:${NC}
  ✓ 自动识别仓库/文件夹/文件
  ✓ 智能同步：自动 init, add, commit, push
  ✓ 分支自动对齐：智能处理 master/main 差异
  ✓ 不指定路径默认下载到当前目录
EOF
  exit 0
}

# 显示帮助
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  usage
fi

if [ -z "$1" ]; then
  usage
fi

# ================= 拉取模式 (Pull) =================
if [[ "$1" == "pull" ]]; then
  TARGET_DIR="${2:-.}"
  TARGET_DIR=$(eval echo "$TARGET_DIR")

  if [ ! -d "$TARGET_DIR" ]; then
    error "目录不存在: $TARGET_DIR"
  fi

  cd "$TARGET_DIR"

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    warn "未检测到 Git 仓库: $TARGET_DIR"
    exit 0
  fi

  CURRENT_DIR=$(pwd)
  step "正在从远程仓库拉取更新..."
  info "当前目录: ${CYAN}$CURRENT_DIR${NC}"

  git pull
  info "拉取完成! ✨"
  exit 0
fi

# ================= 同步模式 (Push) =================
# 检查是否有 -f 参数
FORCE_PUSH=false
if [[ "${@: -1}" == "-f" ]]; then
  FORCE_PUSH=true
  set -- "${@:1:$#-1}"
fi

if [[ "$1" == "push" ]]; then
  shift # 移除 push

  REMOTE_URL=""
  MSG="日常同步更新"

  # 解析参数
  if [[ "$1" == "to" ]]; then
    if [ -z "$2" ]; then error "请提供仓库地址，例如: gits push to https://github.com/xxx/xxx"; fi
    REMOTE_URL="$2"
    MSG="${3:-日常同步更新}"
    shift 2
  else
    MSG="${1:-日常同步更新}"
  fi

  # 1. 检查/初始化仓库
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    step "未检测到 Git 仓库，正在初始化..."
    git init -b main 2>/dev/null || git init
    info "仓库已初始化"
  fi

  # 2. 处理远程仓库
  HAS_ORIGIN=false
  if git remote get-url origin >/dev/null 2>&1; then
    HAS_ORIGIN=true
  fi

  if [ -n "$REMOTE_URL" ]; then
    # 用户指定了地址
    if $HAS_ORIGIN; then
      step "更新远程仓库地址..."
      git remote set-url origin "$REMOTE_URL"
    else
      step "关联远程仓库..."
      git remote add origin "$REMOTE_URL"
    fi
    info "远程仓库已关联: $REMOTE_URL"
  elif ! $HAS_ORIGIN; then
    # 没关联过，也没指定，提示输入
    warn "未关联远程仓库"
    read -p "请输入 GitHub 仓库地址 (回车取消): " INPUT_URL
    if [ -z "$INPUT_URL" ]; then error "已取消"; fi
    git remote add origin "$INPUT_URL"
    info "远程仓库已关联: $INPUT_URL"
  fi

  # 3. 获取当前分支
  CURRENT_BRANCH=$(git branch --show-current)
  if [ -z "$CURRENT_BRANCH" ]; then
    # 刚初始化的仓库可能没有分支名，默认为 main
    CURRENT_BRANCH="main"
    git checkout -b main >/dev/null 2>&1 || true
  fi

  # 4. Add & Commit
  step "正在暂存文件..."
  git add .

  # 检查是否有变更
  if git diff-index --quiet HEAD --; then
    warn "没有检测到文件变更，跳过提交"
  else
    step "正在提交更改..."
    git commit -m "$MSG" >/dev/null 2>&1 || git commit -m "$MSG"
  fi

    # 5. Push (始终推送到远程 main 分支)
    PUSH_ARGS=""
    if $FORCE_PUSH; then
        PUSH_ARGS="-f"
        warn "正在强制推送 (-f)，将覆盖远程版本!"
    fi

    step "正在推送到 GitHub (远程分支: main)..."
    git push -u origin $PUSH_ARGS "$CURRENT_BRANCH":main
    info "推送成功!"

  echo
  info "同步完成! 分支: $CURRENT_BRANCH ✨"
  exit 0
fi

# ================= 下载模式 =================
URL="$1"
TARGET_PATH="${2:-.}"

# 展开 ~ 和变量
TARGET_PATH=$(eval echo "$TARGET_PATH")

# 去掉 .git 后缀和末尾的斜杠
CLEAN_URL="${URL%.git}"
CLEAN_URL="${CLEAN_URL%/}"

# 解析 URL
if [[ "$CLEAN_URL" =~ ^https://github\.com/([^/]+)/([^/]+)/tree/([^/]+)/(.+)$ ]]; then
  MODE="folder"
  OWNER="${BASH_REMATCH[1]}"
  REPO="${BASH_REMATCH[2]}"
  BRANCH="${BASH_REMATCH[3]}"
  PATH_IN_REPO="${BASH_REMATCH[4]}"
  REPO_URL="https://github.com/${OWNER}/${REPO}.git"
  ITEM_NAME=$(basename "$PATH_IN_REPO")
elif [[ "$CLEAN_URL" =~ ^https://github\.com/([^/]+)/([^/]+)/blob/([^/]+)/(.+)$ ]]; then
  MODE="file"
  OWNER="${BASH_REMATCH[1]}"
  REPO="${BASH_REMATCH[2]}"
  BRANCH="${BASH_REMATCH[3]}"
  PATH_IN_REPO="${BASH_REMATCH[4]}"
  ITEM_NAME=$(basename "$PATH_IN_REPO")
  RAW_URL="https://raw.githubusercontent.com/${OWNER}/${REPO}/${BRANCH}/${PATH_IN_REPO}"
elif [[ "$CLEAN_URL" =~ ^https://github\.com/([^/]+)/([^/]+)$ ]]; then
  MODE="repo"
  OWNER="${BASH_REMATCH[1]}"
  REPO="${BASH_REMATCH[2]}"
  REPO_URL="https://github.com/${OWNER}/${REPO}.git"
  ITEM_NAME="$REPO"
else
  error "无法识别的 GitHub 链接格式"
fi

info "模式: ${CYAN}$MODE${NC} | 仓库: ${CYAN}${OWNER}/${REPO}${NC}"

# 处理目标路径
if [[ "$TARGET_PATH" == */ ]]; then
  mkdir -p "$TARGET_PATH"
  FINAL_PATH="$TARGET_PATH/$ITEM_NAME"
else
  if [ -d "$TARGET_PATH" ]; then
    FINAL_PATH="$TARGET_PATH/$ITEM_NAME"
  else
    mkdir -p "$(dirname "$TARGET_PATH")"
    FINAL_PATH="$TARGET_PATH"
  fi
fi

# 冲突处理
if [ -e "$FINAL_PATH" ]; then
  warn "目标已存在: $FINAL_PATH"
  read -p "是否覆盖? [y/N] " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    info "已取消"
    exit 0
  fi
  rm -rf "$FINAL_PATH"
fi

case "$MODE" in
repo)
  step "正在克隆整个仓库 (浅克隆)..."
  git clone --depth=1 "$REPO_URL" "$FINAL_PATH" 2>&1 | while IFS= read -r line; do
    echo -ne "\r\033[K  $line"
  done
  echo
  ;;

folder)
  TMP_DIR=$(mktemp -d)
  trap "rm -rf $TMP_DIR" EXIT

  step "正在获取仓库元数据..."
  git clone --filter=blob:none --no-checkout --single-branch --branch "$BRANCH" "$REPO_URL" "$TMP_DIR" >/dev/null 2>&1

  cd "$TMP_DIR"
  step "正在设置稀疏检出: $PATH_IN_REPO"
  git sparse-checkout init --cone
  git sparse-checkout set "$PATH_IN_REPO"
  git checkout "$BRANCH" >/dev/null 2>&1

  step "正在提取文件夹..."
  cd - >/dev/null
  mkdir -p "$(dirname "$FINAL_PATH")"
  cp -r "$TMP_DIR/$PATH_IN_REPO" "$FINAL_PATH"
  ;;

file)
  step "正在下载文件..."
  curl -L --progress-bar -o "$FINAL_PATH" "$RAW_URL"
  ;;
esac

echo
info "完成! 已保存到: ${CYAN}$FINAL_PATH${NC} ✨"
